PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
# Web app URL for invite links (GitHub Pages):
APP_PUBLIC_URL=https://www.tangent-club.com

# Optional SQLite path (default: server/data/members.db)
# MEMBER_DB_PATH=

# SMTP for invite emails (optional — without SMTP the invite URL is returned in the API response)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tangent-club.com
MAIL_SITE_NAME=Tangent Club

STREAM_KEYS=dev-test-stream-key-change-me
