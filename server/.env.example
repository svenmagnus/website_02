PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
# Web app URL for invite links (GitHub Pages):
# Base URL in invite/verify emails (use apex; add www DNS if you prefer https://www.tangent-club.com)
APP_PUBLIC_URL=https://tangent-club.com

# Optional SQLite path (default: server/data/members.db)
# MEMBER_DB_PATH=

# Platform SMTP — one-time setup sends invite emails for ALL members (Sabine etc.).
# Without this, everyone can still invite via copied link + code (Instagram, WhatsApp).
# Per-user SMTP in the admin UI is optional and not required for normal invites.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tangent-club.com
MAIL_SITE_NAME=Tangent Club

# Encrypts per-user SMTP passwords in SQLite (min. 16 characters)
SMTP_SECRET_KEY=change-me-to-a-long-random-string

# Optional: 4-digit bypass code for host/dev registration without email invite (default 1234)
# DEV_INVITE_CODE=1234

# No verification emails — new accounts can log in immediately
# SKIP_EMAIL_VERIFY=1

# Instant dev login (server-side only). Set to 0 on production VPS when done developing.
# DEV_LOGIN_FALLBACK=0
# DEV_LOGIN_USER=svenmagnus
# DEV_LOGIN_PASS=london12

# Log + return confirm link in API when mail fails (see server console)
# DEV_EXPOSE_VERIFY_URL=1

STREAM_KEYS=dev-test-stream-key-change-me

# WebRTC on VPS (required for OBS WHIP ingest). Use the server's public IPv4.
# Open the same UDP range in ufw (see scripts/setup-hetzner.sh).
# WEBRTC_ANNOUNCED_IP=167.233.30.166
# WEBRTC_UDP_PORT_MIN=10000
# WEBRTC_UDP_PORT_MAX=60000

# Google Calendar OAuth (full sync — create events + invite partner by email)
# Create credentials at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Web client)
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tangent-club.com/api/social/calendar/callback

# Stripe — platform subscription (1-month trial, then EUR 2.95/month)
# Create a recurring Price in Stripe Dashboard (EUR 2.95/month) and paste its price_... ID.
# Webhook endpoint: POST https://tangent-club.com/api/billing/webhook
# Events: checkout.session.completed, customer.subscription.created/updated/deleted
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Trial length for new accounts (days). Default: 30
# SUBSCRIPTION_TRIAL_DAYS=30
