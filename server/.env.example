PORT=8787
PUBLIC_BASE_URL=http://localhost:8787

# After `npm run tunnel` — paste the same URL as WHIP_CLOUDFLARE_TUNNEL_URL in assets/app.js:
# PUBLIC_BASE_URL=https://your-name.trycloudflare.com

# Production (fixed host, Option B):
# PUBLIC_BASE_URL=https://whip.tangent-club.com
# Comma-separated static keys (optional). Keys from POST /api/broadcast/register are always valid while the server runs.
STREAM_KEYS=dev-test-stream-key-change-me
